{
  "name": "a2a-react-ui",
  "version": "1.0.0",
  "description": "A reusable React component for interacting with A2A agents.",
  "source": "src/index.js",
  "main": "dist/main.js",
  "module": "dist/module.js",
  "bin": {
    "a2a-react-ui-demo": "./bin/run-demo.js"
  },
  "files": [
    "dist",
    "src",
    "demo",
    "bin",
    ".parcelrc"
  ],
  "scripts": {
    "start": "npx parcel demo/index.html",
    "build": "npx parcel build src/index.js",
    "build:demo": "npx parcel build demo/index.html --dist-dir demo/dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/a2a-com/ui.git"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "express": "^4.19.2",
    "react-markdown": "^8.0.7",
    "remark-gfm": "^3.0.1",
    "@parcel/transformer-react-refresh-babel": "^2.0.0-alpha.3"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "buffer": "^6.0.3",
    "parcel": "^2.12.0",
    "process": "^0.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
